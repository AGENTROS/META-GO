{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MetaGoPresencePayload",
  "description": "Payload schema for spatial position and rotation events.",
  "type": "object",
  "properties": {
    "user_id": { "type": "string" },
    "position": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },
    "rotation": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    }
  },
  "required": ["position", "rotation"]
}
