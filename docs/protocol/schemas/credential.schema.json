{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MetaGoCredentialPayload",
  "description": "Payload schema for the Credential.Issued domain event.",
  "type": "object",
  "properties": {
    "document_type": { "type": "string" },
    "zk_proof": { "type": "string", "pattern": "^0x[a-fA-F0-9]+$" },
    "issued_at": { "type": "number" },
    "issuer": { "type": "string", "pattern": "^did:metago:.*$" }
  },
  "required": ["document_type", "zk_proof", "issued_at", "issuer"]
}
