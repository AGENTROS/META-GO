{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/recovery/layout,_N_T_/recovery/page,_N_T_/recovery"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/recovery/__PAGE__",
    "/recovery",
    "/_index",
    "/_head"
  ]
}